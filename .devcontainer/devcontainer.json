{
    "name": "C言語開発環境 (PBL)",
    // C++やC言語のコンパイル環境が最初から入っている公式イメージを指定
    "image": "mcr.microsoft.com/devcontainers/cpp:1-debian-12",
    
    // 開発を便利にするVS Codeの拡張機能を自動インストール
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cpptools-extension-pack"
            ]
        }
    }
}